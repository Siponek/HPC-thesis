@startuml ui-layering-node-tree
!theme plain
!include ../shared/theme.puml

' Layout spacing and sizing adjustments
skinparam padding 10
skinparam nodesep 100
skinparam ranksep 90
skinparam ArrowThickness 2
skinparam ArrowColor #555555
skinparam linetype ortho

title UI Layering and Overlay Isolation (Menu Scene)

' Soft warm background for the UI package
package "Main Scene Tree" #FCF8F2 {
  node "Control (root)" as Root #FDEBD0
  node "Background" as Bg #FDEBD0
  node "MainScreenLogo" as Logo #FDEBD0
  node "MainMenuButtons" as Buttons #FDEBD0
  node "CanvasLayer" as Layer #FDEBD0
  
  ' Added a line break to prevent the node from being too wide
  node "VarTreeMainMenu\n(debug tree)" as VarTree #FDEBD0
  note bottom of Buttons #FFFACD
    Primary interactive gameplay/menu controls.
    Subject to normal UI layout flow.
  end note
 
  note left of Layer #FFFACD
    Overlay plane separated
    from main UI flow.
    Useful for diagnostics/debug
    display without
    disturbing gameplay-space
    transform logic.
  end note
}

' Standard top-down tree connections
Root --> Bg
Root --> Logo
Root --> Buttons
Root --> Layer
Layer --> VarTree



legend right
|= Node |= Role |
| Control | Scene root and layout owner |
| MainMenuButtons | Main interaction controls |
| CanvasLayer | Overlay boundary |
| VarTreeMainMenu | Runtime variable inspection UI |
endlegend

@enduml