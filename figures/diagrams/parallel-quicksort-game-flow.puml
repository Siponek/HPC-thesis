@startuml parallel-quicksort-game-flow
!theme plain
!include ../shared/theme.puml

' --- FONT SIZES ---
skinparam TitleFontSize 44
skinparam SwimlaneTitleFontSize 38
skinparam NoteFontSize 38
skinparam ActivityFontSize 38
skinparam ActivityDiamondFontSize 38
skinparam style strictuml
skinparam ArrowThickness 4 
skinparam FooterFontSize 44
skinparam ParticipantFontSize 38
skinparam LegendFontSize 38
skinparam SwimlaneTitleFontSize 38
skinparam SwimlaneBorderThickness 2
skinparam DefaultFontSize 38


' --- COLORS ---
skinparam ActivityDiamondBackgroundColor #FFFFCC
skinparam ActivityBackgroundColor #F0F8FF
skinparam PartitionBackgroundColor #FAFAFA

' title Performing Parallel Quicksort with the Existing Tool

|#LightYellow|System|
|#LightGreen|All Players\nin Sub-Group|
|#LightBlue|Coordinator|

|System|
start
:Generate **n** shuffled cards\nin shared container;
:Initialize recursion stack\nwith full array [0..n-1]\nand all **p** players;

partition "**Phase 1 — Pivot Selection**\n" {
    |Coordinator|
    :Select\npivot card\n(median-of-three\nor random);
    
    note right
      Pivot card
      highlighted
      with glowing
      border.
      ——
      **Maps to:**
      pivot
      selection
      strategy
      in quicksort
    end note
    :Confirm pivot →\nshow partition zones;
}

partition "**Phase 2 — Collaborative Partition**\n" {
    |All Players\nin Sub-Group|
    :Left zone ← cards ≤ pivot\nRight zone ← cards > pivot;
    
    note left
      All players move
      cards simultaneously.
      Pivot marker divides
      the container.
      ——
      **Maps to:** parallel
      partitioning step
    end note
    :Players rearrange cards\naround the pivot;
}

|System|
:Validate\npartition\ncorrectness;
note right
  Check: all cards left
  of pivot ≤ pivot value,
  all cards right > pivot
end note

if (Partition balanced?) then (roughly equal)
    :Assign ~p/2\nplayers\nto each\nsub-array;
    note right
    **Balanced**
    **load**
    end note
else (highly unequal)
    :More players\nassigned to\nlarger\nsub-array;
    note left
      **Load**
      **imbalance!**
      Visual warning
      shown.
      ——
      **Maps to:**
      poor pivot
      → uneven
      workload
    end note
endif

partition "**Phase 3 — Recursive Fork**\n" {
    ' Placing the entire fork inside the Players swimlane 
    ' forces them to pack closely together!
    |All Players\nin Sub-Group|
    fork
        partition "Left Sub-Array\n" #Lavender {
            if (Size > 1?) then (yes)
                :Sub-group repeats\nPhases 1–3 on\nleft partition;
                
                ' THE FIX: Changing to note left completely removes 
                ' the wedge between the two sub-arrays!
                note left
                  Breadcrumb trail
                  shows recursion
                  depth and path.
                  ——
                  **Maps to:**
                  #pragma omp task
                end note
            else (base case)
                :1–2 cards →\ntrivially sorted;
            endif
        }
    fork again
        partition "Right Sub-Array\n" #MistyRose {
            if (Size > 1?) then (yes)
                :Sub-group repeats\nPhases 1–3 on\nright partition;
            else (base case)
                :1–2 cards →\ntrivially sorted;
            endif
        }
    end fork
}

|System|
:All sub-arrays sorted\n→ **Game complete!**;
note left
  Cards are
  sorted. Task tree
  visualization shows
  completed recursion.
  Show stats.
end note
stop

' center footer Players perform Parallel Quicksort using existing shared container and coordination

@enduml