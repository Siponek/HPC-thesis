@startuml web-patch-before-after
!theme plain
!include ../shared/theme.puml

title Web Export Patch: Prototype Path vs Patched Path

rectangle "Before Patch (prototype assumption)" as Before #FFEFEF {
  component "Gameplay Managers" as B_Mgr
  component "GDSync default LocalServer" as B_Local
  cloud "Network path expected by framework" as B_Net

  B_Mgr --> B_Local : sync/rpc calls
  B_Local --> B_Net : framework-native path
}

rectangle "After Patch (web export runtime)" as After #EFF8FF {
  component "Gameplay Managers\n(unchanged call style)" as A_Mgr
  component "GDSyncWebPatch\n(web-only hook)" as A_Patch
  component "LocalServerSignaling\n(replacement local server)" as A_Local
  component "SignalingClient\n(HTTP + SSE)" as A_Sig
  cloud "Python signaling/relay server" as A_Relay

  A_Mgr --> A_Patch : existing sync/rpc usage
  A_Patch --> A_Local : replace default LocalServer reference
  A_Local --> A_Sig : signaling operations
  A_Sig --> A_Relay : HTTP actions + SSE stream
}

Before -[#gray,dashed]-> After : Web export constraints forced\ninterception/replacement strategy

note bottom of After
Key intent: preserve manager-level API usage
while changing transport path for browser compatibility.
end note

@enduml

