@startuml http-sse-architecture
!theme plain
!include ../shared/theme.puml
skinparam componentStyle rectangle

left to right direction

skinparam padding 10
skinparam DefaultFontSize 34
skinparam TitleFontSize 38

skinparam nodesep 120
skinparam ranksep 280
skinparam ArrowThickness 2

' Restored polyline as requested!
skinparam linetype polyline

title HTTP/SSE Relay Architecture

package "Web Browsers" #F4F9FC {
    component "Client 1\n(Host)" as C1 #LightBlue
    component "Client 2" as C2 #LightGreen
    component "Client 3" as C3 #LightGreen
    component "Client N" as CN #LightGreen
}

package "Server Infrastructure" #FCF8F2 {
    component "Relay Server\n(Python/aiohttp)" as RS #Orange {
        component "Lobby Manager" as LM #FFE5B4
        component "SSE Broadcaster" as SSE #FFE5B4
        component "Message Router" as MR #FFE5B4
    }
}

database "In-Memory\nGame State" as GS #LightYellow

' HTTP POST connections (client to server)
C1 -[#Blue]-> RS : HTTP POST\n/api/lobby/*
C2 -[#Blue]-> RS : HTTP POST\n/api/lobby/*
C3 -[#Blue]-> RS : HTTP POST\n/api/lobby/*
CN -[#Blue]-> RS : HTTP POST\n/api/lobby/*

' SSE connections (server to client)
C1 <-[#Green]- RS : SSE Stream\n/api/lobby/events
C2 <-[#Green]- RS : SSE Stream\n/api/lobby/events
C3 <-[#Green]- RS : SSE Stream\n/api/lobby/events
CN <-[#Green]- RS : SSE Stream\n/api/lobby/events

' THE FIX: Connect from the internal "Lobby Manager" (LM) instead of the outer "RS" boundary.
' This physically forces the line to exit the bottom of the server box, 
' completely separating it from the client anchor points on the left edge.
LM -down-> GS : Store/Retrieve

note top of RS #FFFACD
  **Star Topology**
  All traffic routes through
  the relay server.
  
  No direct P2P connections.
end note

note top of C1 #FFFACD
  Host manages
  game authority
end note

legend bottom right
  |= Color |= Direction |
  | <#Blue> | Client -> Server (HTTP POST) |
  | <#Green> | Server -> Client (SSE) |
endlegend

@enduml