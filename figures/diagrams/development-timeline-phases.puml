@startgantt development-timeline-phases
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Arial

' Explicitly style the Gantt chart to show vertical grid lines and clean task boxes
<style>
ganttDiagram {
  timeline {
    LineColor #B0B0B0
    LineThickness 1
  }
  task {
    BackGroundColor #D4E6F1
    LineColor #555555
    Margin 2
  }
  milestone {
    BackGroundColor #D5F5E3
    LineColor #555555
  }
}
</style>

title Development Timeline (Dec 2024 -- Feb 2026)

printscale monthly
