@startuml deployment-authority-boundary
!theme plain
!include ../shared/theme.puml

' --- FONT SIZES & THICKNESS ---
skinparam DefaultFontSize 34
skinparam TitleFontSize 38
skinparam NodeFontSize 34
skinparam ComponentFontSize 34
skinparam LegendFontSize 34
skinparam NoteFontSize 34
skinparam ArrowThickness 4 

' --- SPACING & LAYOUT ---
skinparam nodesep 120
skinparam ranksep 180
skinparam linetype polyline
skinparam style strictuml

title Deployment Context and Authority Boundaries (Web-First Multiplayer)

' HOST NODE (Top)
node "Browser Client A\n(Host authority)" as Host #EAF2F8 {
  component "Game Scenes\n(UI + Card logic)" as HostUI #D4E6F1
  component "ConnectionManager" as HostConn #D4E6F1
  component "MultiplayerCardManager" as HostMCM #A9CCE3
  component "GDSync +\nLocalServerSignaling" as HostSync #D4E6F1
  
  ' MAGIC TRICK: Hidden lines force a 2x2 Grid!
  ' Row 1: UI (left) | Conn (right)
  ' Row 2: MCM (left) | Sync (right)
  HostUI -right[hidden]-> HostConn
  HostUI -down[hidden]-> HostMCM
  HostConn -down[hidden]-> HostSync
}

note bottom of Host #E6F4EA
  **In-process boundary**
  (signals/local callbacks)
  occur internally within 
  each browser node.
end note

' RELAY SERVER (Middle)
cloud "Signaling/Relay Server\n(Python HTTP/SSE)" as Relay #FEF9E7

note left of Relay #FFF4E6
  **Inter-client boundary**
  (HTTP/SSE relay)
  bridges the clients.
end note

' PEER NODES (Bottom)
node "Browser Client B\n(Peer)" as Peer1 #EAFAF1 {
  component "MultiplayerCardManager" as PeerMCM #A9DFBF
  component "GDSync +\nLocalServerSignaling" as PeerSync #D5F5E3
  component "Game Scenes\n(UI + Card logic)" as PeerUI #D5F5E3
  component "ConnectionManager" as PeerConn #D5F5E3
  
  ' 2x2 Grid. Top row connects to Relay/Host
  PeerMCM -right[hidden]-> PeerSync
  PeerMCM -down[hidden]-> PeerUI
  PeerSync -down[hidden]-> PeerConn
}

node "Browser Client C\n(Peer)" as Peer2 #EAFAF1 {
  component "GDSync +\nLocalServerSignaling" as Peer2Sync #D5F5E3
  component "MultiplayerCardManager" as Peer2MCM #A9DFBF
  component "ConnectionManager" as Peer2Conn #D5F5E3
  component "Game Scenes\n(UI + Card logic)" as Peer2UI #D5F5E3
  
  ' 2x2 Grid. Mirrored so Sync is closer to the center Relay
  Peer2Sync -right[hidden]-> Peer2MCM
  Peer2Sync -down[hidden]-> Peer2Conn
  Peer2MCM -down[hidden]-> Peer2UI
}

' --- RELATIONSHIPS ---

' Relay HTTP/SSE Connections (Blue = HTTP, Green = SSE)
HostSync -down[#0055A4]-> Relay : HTTP actions\n(connect/create/\njoin/broadcast)
Relay -up[#27AE60]-> HostSync : SSE events

Relay -down[#27AE60]-> PeerSync : SSE events
Relay -down[#27AE60]-> Peer2Sync : SSE events

PeerSync -up[#0055A4]-> Relay : HTTP actions
Peer2Sync -up[#0055A4]-> Relay : HTTP actions

' MCM Logical Authority Connections (Gray Dashed)
PeerMCM -up[#707B7C,dashed]-> HostMCM : proposes move intent\n(via relay path)
Peer2MCM -up[#707B7C,dashed]-> HostMCM : proposes move intent\n(via relay path)

' Host Self-Validation
HostMCM -right[#27AE60,bold]-> HostMCM : authoritative validation\nand canonical updates

legend bottom right
|= Boundary |= Meaning |
| Host authority | Final move validation and state convergence |
| In-process signals | Local component communication inside one client |
| HTTP/SSE relay | Cross-client event propagation for web deployment |
endlegend

@enduml