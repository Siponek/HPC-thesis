@startuml networking-approach-comparison
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam nodesep 40
skinparam ranksep 40
skinparam roundcorner 10
skinparam ArrowThickness 2

title Architectural Decision: Networking for Browser-First Deployment

' Top Requirement Block
rectangle "<b>Core Requirement: Browser-Compatible Multiplayer</b>\nGodot WebAssembly export requires robust, low-barrier web networking\nthat functions seamlessly across various institutional network policies." as REQ #EAECEE

' Candidate Architectures horizontally aligned
together {
    rectangle "<b>Client-Server (Dedicated)</b>\n----\n<b>Strengths:</b>\n+ Authoritative state\n+ Cheat prevention\n+ Simple client logic\n\n<b>Weaknesses:</b>\n- Persistent server hosting\n- High infrastructure cost\n- Single point of failure" as CS #FDF2E9

    rectangle "<b>Peer-to-Peer (WebRTC)</b>\n----\n<b>Strengths:</b>\n+ Lowest latency\n+ Decentralized resilience\n+ No central game server\n\n<b>Weaknesses:</b>\n- NAT traversal (STUN/TURN)\n- WebRTC browser instability\n- Complex consensus logic" as P2P #FDF2E9

    rectangle "<b>HTTP/SSE Relay</b>\n----\n<b>Strengths:</b>\n+ Universal browser compatibility\n+ Standard APIs (no WebRTC)\n+ Minimal deployment complexity\n\n<b>Weaknesses:</b>\n- Moderate latency (relay bottleneck)\n- Not true peer-to-peer" as RELAY #EAF2F8
}

' Flow from Requirement to Candidates
REQ -down-> CS
REQ -down-> P2P
REQ -down-> RELAY

' Outcome Blocks
rectangle "<color:#C0392B><b>REJECTED</b></color>\n----\nInfrastructure overhead and\nhosting costs are too high;\nunnecessary for a simple\neducational scope." as REJ_CS #FADBD8

rectangle "<color:#C0392B><b>REJECTED</b></color>\n----\nUnreliable in institutional/LAN\nnetworks (NAT failures);\nWebRTC\nAPI issues in WASM exports." as REJ_P2P #FADBD8

rectangle "<color:#27AE60><b>SELECTED</b></color>\n----\nPerfect fit for Godot HTML5.\nReliable, universally supported,\nand extremely cheap to host\nusing standard HTTP POST/SSE." as SEL_RELAY #D5F5E3

' Flow from Candidates to Outcomes
CS -down-> REJ_CS : <color:#C0392B><b>Failed constraints</b></color>
P2P -down-> REJ_P2P : <color:#C0392B><b>Failed constraints</b></color>
RELAY -down-> SEL_RELAY : <color:#27AE60><b>Met all criteria</b></color>

' Invisible links to keep the outcomes strictly aligned at the bottom
REJ_CS -[hidden]right- REJ_P2P
REJ_P2P -[hidden]right- SEL_RELAY

@enduml